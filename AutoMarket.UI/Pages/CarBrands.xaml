<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:persistence="clr-namespace:AutoMarket.Application.CarBrandUseCases.Queries;assembly=AutoMarket.Application"
             xmlns:converters="clr-namespace:AutoMarket.UI.ValueConverters"
             x:Class="AutoMarket.UI.Pages.CarBrands"
             x:Name="CarBrandsPage"
             BackgroundColor="White"
             xmlns:models="clr-namespace:AutoMarket.UI.ViewModels"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             x:DataType="models:CarBrandsViewModel">

    <ContentPage.Resources>
        <ResourceDictionary>
            <converters:PriceToColorConverter x:Key="PriceToColorConverter" />
        </ResourceDictionary>
    </ContentPage.Resources>

    <ContentPage.Behaviors>
        <toolkit:EventToCommandBehavior EventName="Loaded"
                                       Command="{Binding UpdateGroupListCommand}" />
    </ContentPage.Behaviors>

    <ScrollView>
        <VerticalStackLayout Padding="20,10"
                             Spacing="10">

            <Border Stroke="#E0E0E0"
                    StrokeThickness="1"
                    BackgroundColor="#FAFAFA"
                    Padding="10"
                    Margin="0,0,0,10">

                <HorizontalStackLayout Spacing="8"
                                       HorizontalOptions="Start">

                    <Button Text="Create Brand"
                            Command="{Binding CreateBrandCommand}"
                            BackgroundColor="#E8F5E9"
                            TextColor="#2E7D32"
                            FontSize="13"
                            CornerRadius="6"
                            Padding="10,4" />

                    <Button Text="Create Announcement"
                            Command="{Binding AddAnnouncementToCurrentBrandCommand}"
                            BackgroundColor="#E8F5E9"
                            TextColor="#2E7D32"
                            FontSize="13"
                            CornerRadius="6"
                            Padding="10,4" />

                </HorizontalStackLayout>
            </Border>

            <Picker x:Name="CarBrandPicker"
                    Title="Choose brand"
                    TextColor="Black"
                    FontSize="18"
                    FontAttributes="Bold"
                    ItemsSource="{Binding CarBrands}"
                    ItemDisplayBinding="{Binding Name}"
                    SelectedItem="{Binding SelectedBrand}"
                    BackgroundColor="#EDEDED">

                <Picker.Behaviors>
                    <toolkit:EventToCommandBehavior EventName="SelectedIndexChanged"
                                                   Command="{Binding UpdateMembersListCommand}" />
                </Picker.Behaviors>
            </Picker>

            <BoxView HeightRequest="1"
                     Color="#EEEEEE"
                     Margin="0,0,0,5" />

            <HorizontalStackLayout Spacing="10"
                                   VerticalOptions="Center">

                <Label Text="{Binding SelectedBrandInfo}"
                       FontSize="14"
                       TextColor="#424242"
                       Padding="5,0"
                       LineBreakMode="WordWrap"
                       VerticalOptions="Center" />

                <VerticalStackLayout Spacing="5"
                                     VerticalOptions="Center"
                                     IsVisible="{Binding ButtonsAreVisible}">

                    <Button Text="Edit"
                            BackgroundColor="Transparent"
                            TextColor="#3498DB"
                            FontSize="12"
                            WidthRequest="75"
                            HeightRequest="30"
                            CornerRadius="6"
                            BorderWidth="1"
                            BorderColor="#3498DB" 
                            Command="{Binding EditBrandCommand}"
                            CommandParameter="{Binding SelectedBrand}"/>

                    <Button Text="Remove"
                            BackgroundColor="Transparent"
                            TextColor="#E74C3C"
                            FontSize="12"
                            WidthRequest="75"
                            HeightRequest="30"
                            CornerRadius="6"
                            BorderWidth="1"
                            BorderColor="#E74C3C"
                            Command="{Binding RemoveBrandCommand}" />

                </VerticalStackLayout>
            </HorizontalStackLayout>

            <BoxView HeightRequest="1"
                     Color="#F5F5F5"
                     Margin="0,10" />

            <CollectionView ItemsSource="{Binding Announcements}">

                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="persistence:AnnouncementDto">

                        <Border Stroke="#E0E0E0"
                                StrokeThickness="1"
                                Padding="10"
                                Margin="0,5"
                                BackgroundColor="{Binding Price, Converter={StaticResource PriceToColorConverter}}">

                            <VerticalStackLayout Spacing="5">

                                <VerticalStackLayout.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding Source={x:Reference CarBrandsPage}, Path=BindingContext.ShowDetailsCommand}"
                                                          CommandParameter="{Binding}" />
                                </VerticalStackLayout.GestureRecognizers>

                                <Label Text="{Binding Title}"
                                       FontSize="16"
                                       FontAttributes="Bold"
                                       TextColor="#006064" />

                                <Label Text="{Binding Model}"
                                       FontSize="12"
                                       TextColor="Gray" />

                                <Label Text="{Binding Price, StringFormat='${0:N0}'}"
                                       FontSize="14"
                                       FontAttributes="Bold"
                                       TextColor="Black" />

                                <Label Text="{Binding CreatedAt, StringFormat='{0:dd.MM.yyyy}'}"
                                       FontSize="10"
                                       TextColor="Gray" />

                            </VerticalStackLayout>
                        </Border>

                    </DataTemplate>
                </CollectionView.ItemTemplate>

            </CollectionView>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>