<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodels="clr-namespace:AutoMarket.UI.ViewModels"
             x:Class="AutoMarket.UI.Pages.AnnouncementDetails"
             BackgroundColor="White"
             x:DataType="viewmodels:AnnouncementDetailsViewModel"
             xmlns:converters="clr-namespace:AutoMarket.UI.ValueConverters">

    <ContentPage.ToolbarItems>
        <ToolbarItem Text="Edit"
                     Command="{Binding EditAnnouncementCommand}"
                     Order="Primary"
                     Priority="0" />

        <ToolbarItem Text="Remove"
                     Command="{Binding RemoveAnnouncementCommand}"
                     Order="Primary"
                     Priority="1" />
    </ContentPage.ToolbarItems>

    <ContentPage.Resources>
        <converters:IdToImageConverter x:Key="IdToImageConverter" />
    </ContentPage.Resources>

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="15">

            <Frame CornerRadius="10" 
                   HasShadow="True" 
                   Padding="20" 
                   BorderColor="#E0E0E0"
                   BackgroundColor="White">

                <VerticalStackLayout Spacing="10">

                    <Label Text="{Binding Announcement.Title}" 
                           FontSize="24" 
                           FontAttributes="Bold" 
                           TextColor="#212121"/>

                    <Label Text="{Binding Announcement.Price, StringFormat='${0:N0}'}" 
                           FontSize="22" 
                           TextColor="#2E7D32" 
                           FontAttributes="Bold"/>

                    <BoxView HeightRequest="1" Color="#EEEEEE" Margin="0,5"/>

                    <VerticalStackLayout Spacing="10" HorizontalOptions="Center">
                        <Image Source="{Binding Announcement.Id, Converter={StaticResource IdToImageConverter}}" 
                               HeightRequest="300" 
                               WidthRequest="300" 
                               Aspect="AspectFill" />

                        <Button Text="Change Photo"
                                Command="{Binding ChangeImageCommand}"
                                BackgroundColor="#E3F2FD"
                                TextColor="#1976D2"
                                FontSize="12"
                                Padding="15,0"
                                HeightRequest="35"
                                CornerRadius="6"
                                HorizontalOptions="Center" />
                    </VerticalStackLayout>

                    <HorizontalStackLayout Spacing="5" Margin="0,10,0,0">
                        <Label Text="Модель:" FontAttributes="Bold" TextColor="#757575"/>
                        <Label Text="{Binding Announcement.Model}" TextColor="#424242"/>
                    </HorizontalStackLayout>

                    <HorizontalStackLayout Spacing="5">
                        <Label Text="Год выпуска:" FontAttributes="Bold" TextColor="#757575"/>
                        <Label Text="{Binding Announcement.ManufactureYear}" TextColor="#424242"/>
                    </HorizontalStackLayout>

                    <HorizontalStackLayout Spacing="5">
                        <Label Text="Статус:" FontAttributes="Bold" TextColor="#757575"/>
                        <Label Text="{Binding Announcement.Status}" TextColor="#1976D2"/>
                    </HorizontalStackLayout>
                </VerticalStackLayout>
            </Frame>

            <Label Text="Описание" 
                   FontSize="18" 
                   FontAttributes="Bold" 
                   Margin="5,10,0,0"
                   TextColor="#212121"/>

            <Frame CornerRadius="10" 
                   Padding="15" 
                   BorderColor="#E0E0E0"
                   BackgroundColor="#F9F9F9">
                <Label Text="{Binding Announcement.Description}" 
                       FontSize="15"
                       LineHeight="1.2"
                       TextColor="#424242"
                       LineBreakMode="WordWrap"/>
            </Frame>

            <Label Text="{Binding Announcement.CreatedAt, StringFormat='Дата публикации: {0:dd MMMM yyyy}'}" 
                   FontSize="12" 
                   TextColor="#9E9E9E" 
                   HorizontalOptions="Center"
                   Margin="0,10,0,0"/>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>