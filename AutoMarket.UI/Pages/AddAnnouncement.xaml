<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="AutoMarket.UI.Pages.AddAnnouncement"
             xmlns:viewmodels="clr-namespace:AutoMarket.UI.ViewModels"
             BackgroundColor="White"
             x:DataType="viewmodels:AddAnnouncementViewModel">

    <ScrollView>
        <VerticalStackLayout Padding="20,10"
                             Spacing="12">

            <Border Stroke="#E0E0E0"
                    StrokeThickness="1"
                    BackgroundColor="#FAFAFA"
                    Padding="15">

                <VerticalStackLayout Spacing="12">

                    <Label Text="Title"
                           FontSize="13"
                           TextColor="#424242"/>

                    <Entry Text="{Binding Title}"
                           BackgroundColor="#F5F5F5"
                           TextColor="Black"
                           HeightRequest="40"/>

                    <Label Text="Model"
                           FontSize="13"
                           TextColor="#424242"/>

                    <Entry Text="{Binding Model}"
                           BackgroundColor="#F5F5F5"
                           TextColor="Black"
                           HeightRequest="40"/>

                    <Label Text="Price ($)"
                           FontSize="13"
                           TextColor="#424242"/>

                    <Entry Text="{Binding Price}"
                           Keyboard="Numeric"
                           BackgroundColor="#F5F5F5"
                           TextColor="Black"
                           HeightRequest="40"/>
                    
                    <Label Text="Manufacture Year"
                           FontSize="13"
                           TextColor="#424242"/>

                    <Entry Text="{Binding ManufactureYear}"
                           Keyboard="Numeric"
                           BackgroundColor="#F5F5F5"
                           TextColor="Black"
                           HeightRequest="40"/>
                    
                    <Label Text="Description"
                           FontSize="13"
                           TextColor="#424242"/>

                    <Editor Text="{Binding Description}"
                            BackgroundColor="#F5F5F5"
                            TextColor="Black"
                            HeightRequest="100"
                            AutoSize="TextChanges"/>

                </VerticalStackLayout>
            </Border>

            <HorizontalStackLayout Spacing="10"
                                   Margin="0,15,0,0">

                <Button Text="Save"
                        Command="{Binding SaveCommand}"
                        BackgroundColor="#E8F5E9"
                        TextColor="#2E7D32"
                        FontSize="13"
                        CornerRadius="6"
                        Padding="12,6" />

                <Button Text="Cancel"
                        Command="{Binding CancelCommand}"
                        BackgroundColor="Transparent"
                        TextColor="#7F8C8D"
                        FontSize="13" />

            </HorizontalStackLayout>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>